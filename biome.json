{
  "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": "off",
        "noEmptyBlockStatements": "off",
        "useIsArray": "error",
        "noPrototypeBuiltins": "error"
      },
      "style": {
        "noNonNullAssertion": "off",
        "noNamespace": "off",
        "noNegationElse": "warn",
        "useTemplate": "warn",
        "useConst": "error",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false
          }
        }
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noConstantCondition": "warn",
        "noSwitchDeclarations": "off",
        "noInnerDeclarations": "off",
        "useYield": "off"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": "warn"
      },
      "performance": {
        "noAccumulatingSpread": "warn"
      },
      "nursery": {
        "noUnusedExpressions": "error",
        "noContinue": "error",
        "noDuplicateDependencies": "error",
        "noEqualsToNull": "error",
        "noDeprecatedImports": "error",
        "noEmptySource": "error",
        "noFloatingPromises": "error",
        "noForIn": "error",
        "noMisusedPromises": "error",
        "noProto": "error",
        "noShadow": "error",
        "noUnknownAttribute": "error",
        "noUnnecessaryConditions": "error",
        "useMaxParams": {
          "level": "warn",
          "options": {
            "max": 4
          }
        },
        "useFind": "error",
        "useConsistentArrowReturn": "error",
        "noUselessUndefined": "off",
        "noUselessCatchBinding": "error",
        "noUnresolvedImports": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all",
      "bracketSpacing": true
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**/*.js", "**/*.ts", "**/*.jsx", "**/*.tsx", "**/*.json", "**/*.jsonc"]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
