<pelela view-model="DetailSpecial">
  <h1>Detalle de Usuario Especial</h1>
  <p>Estas viendo el detalle del ID: <strong bind-content="id"></strong></p>
  <p>Nombre recuperado por Query Params: <strong bind-content="name"></strong></p>
  
  <br />
  <button click="goBack">Volver al inicio</button>
</pelela>
