{
  "name": "pelela-vscode",
  "version": "0.0.1",
  "type": "commonjs",
  "publisher": "uqbar",
  "displayName": "Pelela Templates",
  "description": "Soporte básico para archivos .pelela (syntax highlighting y snippets).",
  "engines": {
    "vscode": "^1.105.0"
  },
  "main": "./dist/extension.js",
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --external vscode --clean",
    "typecheck": "tsc --noEmit",
    "test": "mocha --require tsx --require test/setup.cjs test/**/*.test.ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "24.10.1",
    "@types/vscode": "1.105.0",
    "@vscode/vsce": "3.7.1",
    "chai": "4.3.10",
    "glob": "13.0.0",
    "mocha": "10.2.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  },
  "contributes": {
    "languages": [
      {
        "id": "pelela",
        "aliases": [
          "Pelela Template",
          "pelela"
        ],
        "extensions": [
          ".pelela"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configurationDefaults": {
      "[pelela]": {
        "editor.suggest.insertMode": "replace",
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": true
        }
      },
      "emmet.includeLanguages": {
        "pelela": "html"
      },
      "html.suggest.html5": true,
      "html.autoClosingTags": true
    },
    "grammars": [
      {
        "language": "pelela",
        "scopeName": "text.html.pelela",
        "path": "./syntaxes/pelela.tmLanguage.json",
        "embeddedLanguages": {
          "text.html": "html",
          "text.html.basic": "html",
          "source.css": "css",
          "source.js": "javascript"
        }
      },
      {
        "scopeName": "pelela.injection",
        "path": "./syntaxes/pelela.tmLanguage.json",
        "injectTo": [
          "text.html.basic",
          "text.html"
        ]
      }
    ],
    "snippets": [
      {
        "language": "pelela",
        "path": "./snippets/pelela.json"
      }
    ],
    "html": {
      "customData": [
        "./html-custom-data.json"
      ]
    }
  }
}
