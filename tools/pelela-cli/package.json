{
  "name": "@pelelajs/cli",
  "version": "1.0.0",
  "description": "CLI tool to bootstrap new PelelaJS projects",
  "bin": {
    "pelela": "./src/index.ts"
  },
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
