    "pelelajs",
    "cli",
    "framework"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "5.6.2",
    "cli-box": "6.0.11",
    "commander": "12.1.0",
    "i18next": "23.7.6"
  },
  "devDependencies": {
    "@types/cli-box": "6.0.4",
    "@types/node": "24.10.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.14"
  }
}
