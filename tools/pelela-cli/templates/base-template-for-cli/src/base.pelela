<h1>Conversor Millas a Kilómetros</h1>

<pelela view-model="Base">
  <label>
    Millas:
    <input type="text" bind-value="miles" />
  </label>

  <button click="convert">Convertir</button>

  <p if="hasKilometers">
    Kilómetros:
    <span
      bind-content="kilometers"
      bind-class="kilometersClass" />
  </p>
</pelela>