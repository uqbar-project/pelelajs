{
  "git": {
    "changelog": "tsx scripts/generate-summary.ts npm",
    "commitMessage": "chore: release npm-v${version}",
    "tagName": "npm-v${version}",
    "requireCleanWorkingDir": true
  },
  "github": {
    "release": true,
    "releaseName": "npm-v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": [
      "pnpm tsx scripts/update-changelog.ts ${version} npm",
      "pnpm -C packages/core version ${version} --no-git-tag-version",
      "pnpm -C packages/vite-plugin-pelelajs version ${version} --no-git-tag-version",
      "pnpm -C tools/pelela-cli version ${version} --no-git-tag-version",
      "pnpm run build"
    ],
    "after:release": [
      "pnpm -C packages/core publish --no-git-checks --access public",
      "pnpm -C packages/vite-plugin-pelelajs publish --no-git-checks --access public",
      "pnpm -C tools/pelela-cli publish --no-git-checks --access public",
      "echo \"✅ Successfully published npm-v${version} to NPM and GitHub!\""
    ]
  }
}
