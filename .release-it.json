{
  "git": {
    "changelog": "tsx scripts/generate-summary.ts npm",
    "commitMessage": "chore: release npm-v${version}",
    "tagName": "npm-v${version}",
    "requireCleanWorkingDir": true,
    "requireBranch": "main"
  },
  "github": {
    "release": true,
    "releaseName": "npm-v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:bump": [
      "node -e \"const { execSync } = require('child_process'); const editor = process.env.EDITOR || 'code'; execSync(`${editor} CHANGELOG.md`, { stdio: 'inherit' });\""
    ],
    "after:bump": [
      "pnpm --filter pelelajs version ${version} --no-git-tag-version",
      "pnpm --filter vite-plugin-pelelajs version ${version} --no-git-tag-version",
      "pnpm --filter pelela-cli version ${version} --no-git-tag-version",
      "pnpm run build"
    ],
    "after:release": [
      "pnpm --filter pelelajs publish --no-git-checks --access public",
      "pnpm --filter vite-plugin-pelelajs publish --no-git-checks --access public",
      "pnpm --filter pelela-cli publish --no-git-checks --access public",
      "echo \"✅ Successfully published npm-v${version} to NPM and GitHub!\""
    ]
  }
}
