{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "pelelajs": ["./packages/core/src/index.ts"],
      "pelelajs/dom": ["./packages/core/src/commons/dom.ts"]
    }
  }
}
